# --- CONFIGURAÇÕES DE BANCO DE DATA (SUPABASE) ---
# Você encontra isso em Settings > Database no painel do Supabase
DATABASE_URL=postgresql://postgres:SUA_SENHA@db.SUA_URL.supabase.co:5432/postgres

# --- CONFIGURAÇÕES DJANGO ---
SECRET_KEY=sua-chave-secreta-gera-uma-nova-para-producao
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app,.onrender.com

# --- CONFIGURAÇÕES SUPABASE FRONTEND (Opcional) ---
# Você encontra isso em Settings > API
VITE_SUPABASE_URL=https://SUA_URL.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-key-aqui

# --- CONFIGURAÇÕES DE API ---
# Link do backend no Render (exemplo)
VITE_API_BASE_URL=https://seu-backend.onrender.com/api/v1
